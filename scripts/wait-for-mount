#!/usr/bin/env bash
# Wait for the configured storage paths to live on a dedicated kernel mount
# (i.e., the closest mountpoint containing them is anything other than `/`).
# Polls every 5 seconds for up to 5 minutes per path. Reads paths from .env
# in the install dir.
#
# Why "containing mount" instead of "is itself a mountpoint": the user's
# DOWNLOADS_DIR may be a subdirectory of a mount (e.g. /mnt/videos/downloads
# inside an /mnt/videos mount), in which case `mountpoint -q` would falsely
# report "not mounted." `findmnt --target` resolves to the closest containing
# mount, which is the question we actually care about.
#
# Run as ExecStartPre by the systemd user unit. CWD is the install dir
# via WorkingDirectory=.
#
# Skipped entirely when ALLOW_NON_MOUNTPOINT=1 — the user has opted into
# plain directories on the root fs.

set -euo pipefail

# shellcheck source=lib/common
source "$(dirname "$0")/lib/common"

ENV_FILE=".env"
[[ -f "$ENV_FILE" ]] || { echo "wait-for-mount: $ENV_FILE not found in $(pwd)" >&2; exit 1; }

allow=$(read_env_value "$ENV_FILE" ALLOW_NON_MOUNTPOINT)
if [[ "$allow" == "1" ]]; then
  echo "wait-for-mount: ALLOW_NON_MOUNTPOINT=1 — skipping mount check"
  exit 0
fi

dl=$(read_env_value "$ENV_FILE" DOWNLOADS_DIR)
comp=$(read_env_value "$ENV_FILE" COMPLETED_DIR)
[[ -n "$dl"   ]] || { echo "wait-for-mount: DOWNLOADS_DIR not set in $ENV_FILE" >&2; exit 1; }
[[ -n "$comp" ]] || { echo "wait-for-mount: COMPLETED_DIR not set in $ENV_FILE" >&2; exit 1; }

TIMEOUT=300
INTERVAL=5

wait_one() {
  local path="$1" elapsed=0 mp
  while (( elapsed < TIMEOUT )); do
    mp=$(findmnt -no TARGET --target "$path" 2>/dev/null || echo "/")
    if [[ "$mp" != "/" ]]; then
      echo "wait-for-mount: $path on $mp"
      return 0
    fi
    sleep "$INTERVAL"
    elapsed=$((elapsed + INTERVAL))
  done
  echo "wait-for-mount: $path still on root fs after ${TIMEOUT}s" >&2
  return 1
}

wait_one "$dl"
[[ "$comp" == "$dl" ]] || wait_one "$comp"
