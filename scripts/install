#!/usr/bin/env bash
set -euo pipefail

# Install the systemd user service for the prowlarr stack.
# Usage: scripts/install

cd "$(dirname "$0")/.."

banner() { echo "==> $1"; }

source_dir="$(pwd)"
unit_src="defaults/prowlarr-stack.service"
unit_dst="$HOME/.config/systemd/user/prowlarr-stack.service"
service_name="prowlarr-stack"

# 1. Install patched systemd unit
banner "Installing systemd unit to $unit_dst"
mkdir -p "$(dirname "$unit_dst")"
sed \
  -e "s|WorkingDirectory=.*|WorkingDirectory=$source_dir|" \
  "$unit_src" > "$unit_dst"

# 2. Reload systemd
banner "Reloading systemd"
systemctl --user daemon-reload

# 3. Enable on login
banner "Enabling service"
systemctl --user enable "$service_name"

# 4. Restart service if active
if systemctl --user is-active --quiet "$service_name"; then
  banner "Restarting service"
  systemctl --user restart "$service_name"
fi

# 5. Status summary
banner "Install complete"
echo "  Source:  $source_dir"
echo "  Unit:    $unit_dst"
echo ""
systemctl --user status "$service_name" --no-pager 2>/dev/null || echo "  Service is not running. Start with: systemctl --user start $service_name"
