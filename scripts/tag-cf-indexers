#!/usr/bin/env bash
# scripts/tag-cf-indexers — tag Cloudflare-protected indexers so Prowlarr routes
# them through the byparr (FlareSolverr-API) solver.
#
# Prowlarr applies an indexer proxy ONLY to indexers that share a tag with it, so
# a Cloudflare-gated indexer must carry the solver's tag or it never uses it.
# This tests each enabled indexer and adds the `byparr` tag to any whose test is
# blocked by Cloudflare, then re-tests. Idempotent; never removes tags; leaves
# working (non-CF) indexers untouched — a tagged indexer routes ALL its searches
# through the slower browser solver, so only the ones that need it get tagged.
#
# Requires the stack running (reads Prowlarr's API on localhost:9696) and sqlite3.
#
# Usage: tag-cf-indexers [--dry-run] [--url URL] [--tag NAME]
set -euo pipefail
cd "$(dirname "$0")/.."
# shellcheck source=lib/common
source scripts/lib/common

DRY_RUN=0
URL="http://127.0.0.1:9696"
TAGNAME="byparr"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) DRY_RUN=1; shift ;;
    --url) URL="${2:?}"; shift 2 ;;
    --tag) TAGNAME="${2:?}"; shift 2 ;;
    -h|--help) sed -n '2,15p' "$0"; exit 0 ;;
    *) die "unknown flag: $1 (try --help)" ;;
  esac
done

command -v sqlite3 >/dev/null || die "sqlite3 is required"
KEY=$(fetch_prowlarr_api_key) || die "could not read Prowlarr API key (is the stack set up and running?)"
BASE="$URL/api/v1"

_get() { curl -fsS --max-time 30 -H "X-Api-Key: $KEY" "$BASE$1"; }
_post() { curl -fsS --max-time 60 -X POST -H "X-Api-Key: $KEY" -H "Content-Type: application/json" -d "$2" "$BASE$1"; }
_put()  { curl -fsS --max-time 60 -X PUT  -H "X-Api-Key: $KEY" -H "Content-Type: application/json" -d "$2" "$BASE$1"; }

# Evaluate a scalar SQLite JSON expression (variable `j` = the JSON) over a string.
jexpr() {  # jexpr <json-string> <expr using j>
  local jf; jf=$(mktemp)
  printf '%s' "$1" > "$jf"
  sqlite3 :memory: "SELECT $2 FROM (SELECT readfile('$jf') AS j);"
  rm -f "$jf"
}

# --- ensure the tag exists, resolve its id ---
tagid=$(jexpr "$(_get /tag)" \
  "(SELECT json_extract(value,'\$.id') FROM json_each(j) WHERE json_extract(value,'\$.label')='$TAGNAME' LIMIT 1)")
if [[ -z "$tagid" ]]; then
  if [[ $DRY_RUN -eq 1 ]]; then
    log_info "(dry-run) would create tag '$TAGNAME'"
    tagid="?"
  else
    tagid=$(jexpr "$(_post /tag "{\"label\":\"$TAGNAME\"}")" "json_extract(j,'\$.id')")
    log_ok "tag" "created '$TAGNAME' (id $tagid)"
  fi
else
  log_info "tag '$TAGNAME' exists (id $tagid)"
fi

# --- iterate enabled indexers ---
all=$(_get /indexer)
ids=$(jexpr "$all" \
  "(SELECT group_concat(json_extract(value,'\$.id'),' ') FROM json_each(j) WHERE json_extract(value,'\$.enable')=1)")

n_ok=0; n_tagged=0; n_stuck=0; n_other=0
for id in $ids; do
  def=$(_get "/indexer/$id")
  name=$(jexpr "$def" "json_extract(j,'\$.name')")

  # Test (capture body + status; -f would hide the 400 error body we need).
  bodyf=$(mktemp)
  http=$(curl -s -o "$bodyf" -w '%{http_code}' --max-time 150 \
    -X POST -H "X-Api-Key: $KEY" -H "Content-Type: application/json" -d "$def" "$BASE/indexer/test")
  body=$(cat "$bodyf"); rm -f "$bodyf"

  if [[ "$http" == "200" || "$http" == "202" ]]; then
    log_ok "$name" "ok"
    n_ok=$((n_ok + 1))
    continue
  fi
  if ! grep -qi 'cloudflare' <<<"$body"; then
    log_warn "$name: fails (not Cloudflare) — leaving untagged"
    n_other=$((n_other + 1))
    continue
  fi

  # Cloudflare-blocked. Ensure the tag is on it.
  has=$(jexpr "$def" "(SELECT COUNT(*) FROM json_each(json_extract(j,'\$.tags')) WHERE value=$tagid)")
  if [[ "$has" -ge 1 ]]; then
    log_warn "$name: Cloudflare-blocked but already tagged '$TAGNAME' — solver can't clear it"
    n_stuck=$((n_stuck + 1))
    continue
  fi

  if [[ $DRY_RUN -eq 1 ]]; then
    log_info "(dry-run) would tag '$name' with '$TAGNAME' and re-test"
    n_tagged=$((n_tagged + 1))
    continue
  fi

  newdef=$(jexpr "$def" "json_insert(j,'\$.tags[#]',$tagid)")
  _put "/indexer/$id" "$newdef" >/dev/null

  # Re-test through the solver.
  rbody=$(mktemp)
  rhttp=$(curl -s -o "$rbody" -w '%{http_code}' --max-time 150 \
    -X POST -H "X-Api-Key: $KEY" -H "Content-Type: application/json" -d "$newdef" "$BASE/indexer/test")
  rm -f "$rbody"
  if [[ "$rhttp" == "200" || "$rhttp" == "202" ]]; then
    log_ok "$name" "tagged '$TAGNAME' → now passing"
    n_tagged=$((n_tagged + 1))
  else
    log_warn "$name: tagged '$TAGNAME' but still failing (HTTP $rhttp) — likely the VPN exit IP"
    n_stuck=$((n_stuck + 1))
  fi
done

echo ""
log_info "summary: $n_ok ok, $n_tagged tagged, $n_stuck still-stuck, $n_other non-CF failures"
