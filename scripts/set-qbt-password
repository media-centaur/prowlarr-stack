#!/usr/bin/env python3
"""Set WebUI\\Password_PBKDF2 in a qBittorrent.conf file.

Usage: set-qbt-password <qBittorrent.conf>

Reads the plaintext password from stdin (trailing newline stripped), generates
a fresh 16-byte salt and PBKDF2-HMAC-SHA512 hash (100000 iterations, 64 bytes),
and writes the line

    WebUI\\Password_PBKDF2="@ByteArray(<salt_b64>:<hash_b64>)"

into the [Preferences] section, replacing any existing line of the same key.
"""
import base64
import hashlib
import os
import re
import sys


def main() -> int:
    if len(sys.argv) != 2:
        print(f"usage: {os.path.basename(sys.argv[0])} <qBittorrent.conf>", file=sys.stderr)
        return 2

    conf_path = sys.argv[1]
    password = sys.stdin.read().rstrip("\n").encode("utf-8")
    if not password:
        print("error: empty password on stdin", file=sys.stderr)
        return 1

    salt = os.urandom(16)
    digest = hashlib.pbkdf2_hmac("sha512", password, salt, 100000, 64)
    hash_value = f"@ByteArray({base64.b64encode(salt).decode()}:{base64.b64encode(digest).decode()})"
    line = f'WebUI\\Password_PBKDF2="{hash_value}"'

    try:
        with open(conf_path, "r") as f:
            content = f.read()
    except FileNotFoundError:
        print(f"error: {conf_path} not found", file=sys.stderr)
        return 1

    pattern = re.compile(r"^WebUI\\Password_PBKDF2=.*$", re.MULTILINE)
    if pattern.search(content):
        new_content = pattern.sub(lambda _: line, content)
    else:
        pref = re.search(r"^\[Preferences\][^\n]*\n", content, re.MULTILINE)
        if pref:
            insert_at = pref.end()
            new_content = content[:insert_at] + line + "\n" + content[insert_at:]
        else:
            trailing_nl = "" if content.endswith("\n") else "\n"
            new_content = f"{content}{trailing_nl}[Preferences]\n{line}\n"

    st = os.stat(conf_path)
    tmp = f"{conf_path}.tmp.{os.getpid()}"
    with open(tmp, "w") as f:
        f.write(new_content)
    os.chmod(tmp, st.st_mode & 0o777)
    os.replace(tmp, conf_path)
    return 0


if __name__ == "__main__":
    sys.exit(main())
