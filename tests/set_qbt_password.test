#!/usr/bin/env bash
set -u

SCRIPT="${SCRIPT:-scripts/set-qbt-password}"

# Random base64 passwords routinely contain sequences like \P, \1, \g that
# re.sub treats as backreferences in its replacement string. The regression
# this test guards against is passing the replacement as a string instead of
# a literal-returning lambda.

_make_conf() {
  local path="$1"
  cat > "$path" <<'EOF'
[Preferences]
WebUI\Port=8080
WebUI\Username=admin
WebUI\Password_PBKDF2="@ByteArray(old:hash)"
EOF
}

test_replaces_existing_password_line() {
  local tmp; tmp=$(mktemp --suffix=.conf)
  _make_conf "$tmp"
  printf 'plain-password\n' | "$SCRIPT" "$tmp"
  grep -q '^WebUI\\Password_PBKDF2="@ByteArray(' "$tmp"
  ! grep -q 'old:hash' "$tmp"
  rm -f "$tmp"
}

test_handles_password_with_backslash_p() {
  # Reproduces the original bug: previously this raised
  #   re.PatternError: bad escape \P at position 5
  local tmp; tmp=$(mktemp --suffix=.conf)
  _make_conf "$tmp"
  printf 'PassWord\n' | "$SCRIPT" "$tmp"
  grep -q '^WebUI\\Password_PBKDF2="@ByteArray(' "$tmp"
  rm -f "$tmp"
}

test_inserts_under_preferences_when_missing() {
  local tmp; tmp=$(mktemp --suffix=.conf)
  cat > "$tmp" <<'EOF'
[Preferences]
WebUI\Port=8080
EOF
  printf 'pw\n' | "$SCRIPT" "$tmp"
  grep -q '^WebUI\\Password_PBKDF2=' "$tmp"
  rm -f "$tmp"
}

test_appends_preferences_section_when_missing() {
  local tmp; tmp=$(mktemp --suffix=.conf)
  printf '[Other]\nfoo=bar\n' > "$tmp"
  printf 'pw\n' | "$SCRIPT" "$tmp"
  grep -q '^\[Preferences\]' "$tmp"
  grep -q '^WebUI\\Password_PBKDF2=' "$tmp"
  rm -f "$tmp"
}

test_rejects_empty_password() {
  local tmp; tmp=$(mktemp --suffix=.conf)
  _make_conf "$tmp"
  ! printf '' | "$SCRIPT" "$tmp" 2>/dev/null
  rm -f "$tmp"
}
