#!/usr/bin/env bash
# Interactive turn-key installer for prowlarr-stack.
# Usage:
#   ./setup                  interactive, uses existing .env values as defaults
#   ./setup --reconfigure    re-prompts every field
#   ./setup --non-interactive skips prompts; fails fast on missing required vars
set -euo pipefail

cd "$(dirname "$0")"
source scripts/lib/common

# --- flags ---
RECONFIGURE=0
NONINTERACTIVE=0
for arg in "$@"; do
  case "$arg" in
    --reconfigure) RECONFIGURE=1 ;;
    --non-interactive) NONINTERACTIVE=1 ;;
    -h|--help)
      cat <<HELP
Usage: ./setup [--reconfigure] [--non-interactive]

  (no flags)          interactive install, uses .env values as defaults
  --reconfigure       re-prompt every field even if .env has a value
  --non-interactive   skip prompts; fail fast on missing required vars
HELP
      exit 0
      ;;
    *) die "unknown flag: $arg (try --help)" ;;
  esac
done

echo ""
stack_version=""
[[ -f .version ]] && stack_version=$(cat .version)
if [[ -n "$stack_version" ]]; then
  echo "${COLOR_BOLD}prowlarr-stack installer${COLOR_RESET}  ${COLOR_DIM}${stack_version}${COLOR_RESET}"
else
  echo "${COLOR_BOLD}prowlarr-stack installer${COLOR_RESET}"
fi

# --- Phase 1: prerequisites ---
log_phase "prerequisites"
run_prereqs || die "fix missing prerequisites and re-run ./setup"

# --- Phase 2: configuration ---
log_phase "configuration"

ENV_FILE=".env"
touch "$ENV_FILE"
chmod 600 "$ENV_FILE"

# Read existing values (empty string if absent).
wg_key=$(read_env_value "$ENV_FILE" WIREGUARD_PRIVATE_KEY)
countries=$(read_env_value "$ENV_FILE" SERVER_COUNTRIES)
lan_ip=$(read_env_value "$ENV_FILE" HOST_LAN_IP)
lan_subnet=$(read_env_value "$ENV_FILE" LAN_SUBNET)
downloads_dir=$(read_env_value "$ENV_FILE" DOWNLOADS_DIR)
completed_dir=$(read_env_value "$ENV_FILE" COMPLETED_DIR)
allow_non_mountpoint=$(read_env_value "$ENV_FILE" ALLOW_NON_MOUNTPOINT)
[[ -z "$allow_non_mountpoint" ]] && allow_non_mountpoint=0
qbt_use_vpn=$(read_env_value "$ENV_FILE" QBITTORRENT_USE_VPN)
[[ -z "$qbt_use_vpn" ]] && qbt_use_vpn=0

# Provider selection (first, since it drives what else we ask for).
provider=$(read_env_value "$ENV_FILE" VPN_SERVICE_PROVIDER)
if [[ -z "$provider" || $RECONFIGURE -eq 1 ]]; then
  if [[ $NONINTERACTIVE -eq 1 ]]; then
    die "VPN_SERVICE_PROVIDER is not set in .env and --non-interactive was passed"
  fi
  log_info "Supported providers: ${!VPN_PROVIDERS[*]}"
  provider=$(prompt_with_default "VPN provider" "${provider:-nordvpn}" validate_vpn_provider)
fi
validate_vpn_provider "$provider" >/dev/null 2>&1 || die "invalid VPN_SERVICE_PROVIDER in .env: $provider"

# Provider-specific key source hint, then the key prompt.
if [[ -z "$wg_key" || $RECONFIGURE -eq 1 ]]; then
  if [[ $NONINTERACTIVE -eq 1 ]]; then
    die "WIREGUARD_PRIVATE_KEY is not set in .env and --non-interactive was passed"
  fi
  log_info "$(provider_key_hint "$provider")"
  wg_key=$(prompt_secret "WireGuard private key (44-char base64)" validate_wg_key)
fi
validate_wg_key "$wg_key" >/dev/null 2>&1 || die "invalid WireGuard key in .env: ${wg_key:0:4}…"

# Conditional: addresses.
wg_addresses=$(read_env_value "$ENV_FILE" WIREGUARD_ADDRESSES)
if provider_needs_addresses "$provider"; then
  if [[ -z "$wg_addresses" || $RECONFIGURE -eq 1 ]]; then
    if [[ $NONINTERACTIVE -eq 1 ]]; then
      # Only listed providers that strictly require it should die; unknown
      # providers in non-interactive mode accept blank silently.
      if [[ -n "${VPN_PROVIDERS[$provider]:-}" ]]; then
        die "$provider requires WIREGUARD_ADDRESSES; not set in .env"
      fi
    else
      wg_addresses=$(prompt_with_default "WireGuard addresses (e.g. 10.64.222.21/32, blank if unused)" "${wg_addresses:- }")
      [[ "$wg_addresses" == " " ]] && wg_addresses=""
    fi
  fi
fi

# Conditional: preshared key.
wg_preshared=$(read_env_value "$ENV_FILE" WIREGUARD_PRESHARED_KEY)
if provider_needs_preshared "$provider"; then
  if [[ -z "$wg_preshared" || $RECONFIGURE -eq 1 ]]; then
    if [[ $NONINTERACTIVE -eq 1 ]]; then
      if [[ -n "${VPN_PROVIDERS[$provider]:-}" ]]; then
        die "$provider requires WIREGUARD_PRESHARED_KEY; not set in .env"
      fi
    else
      # Empty is acceptable for unknown providers; validator runs only if non-empty.
      wg_preshared=$(prompt_with_default "WireGuard preshared key (blank if unused)" "${wg_preshared:- }")
      [[ "$wg_preshared" == " " ]] && wg_preshared=""
      if [[ -n "$wg_preshared" ]]; then
        validate_wg_key "$wg_preshared" 2>/dev/null || die "preshared key has wrong format (expected 44-char base64)"
      fi
    fi
  fi
fi

# Countries.
if [[ -z "$countries" ]]; then countries="Netherlands"; fi
if [[ $RECONFIGURE -eq 1 || -z "$(read_env_value "$ENV_FILE" SERVER_COUNTRIES)" ]]; then
  if [[ $NONINTERACTIVE -eq 0 ]]; then
    countries=$(prompt_with_default "Exit country (or comma-separated list)" "$countries")
  fi
fi

# LAN IP — auto-detect if missing.
if [[ -z "$lan_ip" || $RECONFIGURE -eq 1 ]]; then
  local_detected=$(detect_host_lan_ip || echo "")
  if [[ $NONINTERACTIVE -eq 1 ]]; then
    [[ -n "$local_detected" ]] || die "cannot auto-detect HOST_LAN_IP and --non-interactive was passed"
    lan_ip="$local_detected"
  else
    default_ip="${lan_ip:-$local_detected}"
    if [[ -z "$default_ip" ]]; then
      lan_ip=$(prompt_with_default "Host LAN IP" "" validate_ipv4)
    else
      lan_ip=$(prompt_with_default "Host LAN IP" "$default_ip" validate_ipv4)
    fi
  fi
fi
validate_ipv4 "$lan_ip" >/dev/null || die "invalid HOST_LAN_IP: $lan_ip"

# LAN subnet — auto-detect if missing.
if [[ -z "$lan_subnet" || $RECONFIGURE -eq 1 ]]; then
  subnet_detected=$(detect_lan_subnet "$lan_ip" || echo "")
  if [[ $NONINTERACTIVE -eq 1 ]]; then
    [[ -n "$subnet_detected" ]] || die "cannot auto-detect LAN_SUBNET and --non-interactive was passed"
    lan_subnet="$subnet_detected"
  else
    default_subnet="${lan_subnet:-$subnet_detected}"
    if [[ -z "$default_subnet" ]]; then
      lan_subnet=$(prompt_with_default "LAN subnet (CIDR)" "" validate_cidr)
    else
      lan_subnet=$(prompt_with_default "LAN subnet (CIDR)" "$default_subnet" validate_cidr)
    fi
  fi
fi
validate_cidr "$lan_subnet" >/dev/null || die "invalid LAN_SUBNET: $lan_subnet"

# Storage paths — host-side bind mount targets for qBittorrent.
# Defaults match the legacy hardcoded layout so a returning user just hits Enter.
if [[ -z "$downloads_dir" || $RECONFIGURE -eq 1 ]]; then
  if [[ $NONINTERACTIVE -eq 1 ]]; then
    [[ -n "$downloads_dir" ]] || die "DOWNLOADS_DIR not set in .env and --non-interactive was passed"
  else
    downloads_dir=$(prompt_with_default "Downloads dir (host path bind-mounted to /downloads)" "${downloads_dir:-/mnt/videos/downloads}")
  fi
fi
if [[ -z "$completed_dir" || $RECONFIGURE -eq 1 ]]; then
  if [[ $NONINTERACTIVE -eq 1 ]]; then
    [[ -n "$completed_dir" ]] || die "COMPLETED_DIR not set in .env and --non-interactive was passed"
  else
    completed_dir=$(prompt_with_default "Completed dir (host path bind-mounted to /downloads/completed)" "${completed_dir:-/mnt/videos/completed}")
  fi
fi
[[ "$downloads_dir" = /* ]] || die "DOWNLOADS_DIR must be an absolute path: $downloads_dir"
[[ "$completed_dir" = /* ]] || die "COMPLETED_DIR must be an absolute path: $completed_dir"
[[ "$downloads_dir" != "$completed_dir" ]] || die "DOWNLOADS_DIR and COMPLETED_DIR must be different paths"

# qBittorrent network mode — direct via ISP (default, recommended) or
# tunneled through gluetun. The recommendation is direct because:
#   - downloads run at full ISP speed (VPN tunnels cap bandwidth + add latency)
#   - inbound peer connections work, so seeding actually works
#   - your indexer browsing in Prowlarr is still hidden by gluetun either way
# Tunneling qBT only helps if you specifically need qBT's IP hidden from
# peers, and you accept the speed hit + (for most providers) the loss of
# inbound peers, which makes seeding outgoing-only.
if [[ -z "$(read_env_value "$ENV_FILE" QBITTORRENT_USE_VPN)" || $RECONFIGURE -eq 1 ]]; then
  if [[ $NONINTERACTIVE -eq 0 ]]; then
    echo ""
    log_info "qBittorrent network routing"
    log_info "  ${COLOR_BOLD}Direct (recommended):${COLOR_RESET} qBT goes via your ISP — full speed, full"
    log_info "    peer connectivity for seeding. Your Prowlarr indexer browsing is still"
    log_info "    routed through the VPN regardless of this choice."
    log_info "  ${COLOR_BOLD}Tunneled:${COLOR_RESET} qBT shares gluetun's namespace. Your IP is hidden from"
    log_info "    peers, BUT downloads are capped at VPN speed and most providers don't"
    log_info "    forward inbound ports — seeding becomes outgoing-only."
    if prompt_yes_no "Route qBittorrent through the VPN tunnel?" n; then
      qbt_use_vpn=1
    else
      qbt_use_vpn=0
    fi
  fi
fi
case "$qbt_use_vpn" in 0|1) ;; *) die "QBITTORRENT_USE_VPN must be 0 or 1 (got: $qbt_use_vpn)" ;; esac

# --- Phase 3: write .env ---
log_phase "writing .env"
write_env_value "$ENV_FILE" VPN_SERVICE_PROVIDER "$provider"
write_env_value "$ENV_FILE" WIREGUARD_PRIVATE_KEY "$wg_key"
write_env_value "$ENV_FILE" WIREGUARD_ADDRESSES "$wg_addresses"
write_env_value "$ENV_FILE" WIREGUARD_PRESHARED_KEY "$wg_preshared"
write_env_value "$ENV_FILE" SERVER_COUNTRIES "$countries"
write_env_value "$ENV_FILE" HOST_LAN_IP "$lan_ip"
write_env_value "$ENV_FILE" LAN_SUBNET "$lan_subnet"
write_env_value "$ENV_FILE" DOWNLOADS_DIR "$downloads_dir"
write_env_value "$ENV_FILE" COMPLETED_DIR "$completed_dir"
write_env_value "$ENV_FILE" ALLOW_NON_MOUNTPOINT "$allow_non_mountpoint"
write_env_value "$ENV_FILE" QBITTORRENT_USE_VPN "$qbt_use_vpn"
# COMPOSE_FILE is read by docker compose itself from .env — every `docker
# compose` invocation in this dir picks up the right overlay automatically.
if [[ "$qbt_use_vpn" == "1" ]]; then
  write_env_value "$ENV_FILE" COMPOSE_FILE "docker-compose.yml:docker-compose.qbt-vpn.yml"
else
  write_env_value "$ENV_FILE" COMPOSE_FILE "docker-compose.yml"
fi
log_ok ".env" "written (chmod 600)"

# direnv integration (opt-in, off by default).
#
# Background for the user: direnv is a shell add-on that auto-loads env vars
# from a per-directory .envrc when you cd into the dir. With `dotenv` in
# .envrc, your `.env` becomes part of your shell environment whenever
# you're inside the install dir.
#
# Why we ASK rather than just doing it: most users don't need it. The
# stack's wrapper scripts (./scripts/start, ./check, etc.) cd into the
# install dir before running docker compose, which already auto-reads
# .env from CWD. direnv only adds value if you like running raw
# `docker compose ...` commands from inside the install dir and want
# COMPOSE_FILE / DOWNLOADS_DIR / etc. set in your shell automatically.
#
# Default no — recommend yes only if you're a direnv user already and
# know you'll want this.
if [[ $NONINTERACTIVE -eq 0 ]] && command -v direnv >/dev/null 2>&1 && [[ ! -f .envrc ]]; then
  echo ""
  log_info "direnv detected. Creating ${COLOR_BOLD}.envrc${COLOR_RESET} (one line: ${COLOR_DIM}dotenv${COLOR_RESET}) makes your shell"
  log_info "auto-load .env when you cd into this dir, so raw \`docker compose ...\` commands"
  log_info "pick up COMPOSE_FILE etc. without you sourcing anything."
  log_info "${COLOR_DIM}Skip this if you only use the wrapper scripts — they don't need it.${COLOR_RESET}"
  if prompt_yes_no "create .envrc?" n; then
    echo "dotenv" > .envrc
    direnv allow . 2>/dev/null || log_warn "direnv allow failed — run it manually"
    log_ok ".envrc" "created and allowed"
  fi
fi

# --- Phase 4: seed config/ from defaults/ ---
log_phase "seeding config/"
files=(
  "defaults/prowlarr/config.xml:config/prowlarr/config.xml"
  "defaults/prowlarr/prowlarr.db:config/prowlarr/prowlarr.db"
  "defaults/qbittorrent/qBittorrent.conf:config/qbittorrent/qBittorrent/qBittorrent.conf"
  "defaults/qbittorrent/categories.json:config/qbittorrent/qBittorrent/categories.json"
  "defaults/sabnzbd/sabnzbd.ini:config/sabnzbd/sabnzbd.ini"
)
for entry in "${files[@]}"; do
  src="${entry%%:*}"
  dst="${entry##*:}"
  if [[ ! -f "$src" ]]; then
    log_warn "$src missing from defaults — skipping"
    continue
  fi
  if [[ -f "$dst" ]]; then
    log_ok "$dst" "already present"
    continue
  fi
  mkdir -p "$(dirname "$dst")"
  cp "$src" "$dst"
  log_ok "$dst" "seeded"
done

# --- Phase 5: qBittorrent static password ---
# Resolved before the prowlarr-db patch so the same value can be pushed into
# both qBittorrent's conf and Prowlarr's download-client row in one pass.
log_phase "qBittorrent password"
qbt_pw=$(read_env_value "$ENV_FILE" QBITTORRENT_PASSWORD)
if [[ -z "$qbt_pw" ]]; then
  qbt_pw="adminadmin"
  write_env_value "$ENV_FILE" QBITTORRENT_PASSWORD "$qbt_pw"
  log_ok "QBITTORRENT_PASSWORD" "default 'adminadmin' saved to .env"
else
  log_ok "QBITTORRENT_PASSWORD" "read from .env"
fi
QBT_CONF="config/qbittorrent/qBittorrent/qBittorrent.conf"
if [[ -f "$QBT_CONF" ]]; then
  printf '%s' "$qbt_pw" | ./scripts/set-qbt-password "$QBT_CONF"
  log_ok "$QBT_CONF" "PBKDF2 hash written"
else
  log_warn "$QBT_CONF not present — skipping password injection"
fi

# --- Phase 6: patch Prowlarr DB ---
# In VPN mode prowlarr and qBittorrent share gluetun's network namespace, so
# prowlarr reaches qBT via 127.0.0.1. In direct mode they're on different
# networks; prowlarr reaches qBT via the host's LAN IP.
qbt_host="$lan_ip"
[[ "$qbt_use_vpn" == "1" ]] && qbt_host="127.0.0.1"
log_phase "patching prowlarr.db → qbittorrent@${qbt_host}:8080"
if [[ -f config/prowlarr/prowlarr.db ]]; then
  printf '%s' "$qbt_pw" | ./scripts/patch-prowlarr-db config/prowlarr/prowlarr.db "$qbt_host" 8080 -
  log_ok "prowlarr.db" "download-client host = $qbt_host, password synced"
else
  log_warn "config/prowlarr/prowlarr.db not present — skipping patch"
fi

# --- Phase 6b: SABnzbd (usenet) config + DB wiring ---
# SABnzbd always runs direct (never in gluetun's netns), so Prowlarr reaches it
# at the host LAN IP:8085. Provider credentials come from .env (empty until the
# user has a Usenet account); the API key is generated once and shared into both
# SABnzbd's config and Prowlarr's download-client row.
log_phase "SABnzbd (usenet)"

sab_api_key=$(read_env_value "$ENV_FILE" SABNZBD_API_KEY)
if [[ -z "$sab_api_key" ]]; then
  sab_api_key=$(python3 -c 'import secrets; print(secrets.token_hex(16))')
  write_env_value "$ENV_FILE" SABNZBD_API_KEY "$sab_api_key"
  log_ok "SABNZBD_API_KEY" "generated and saved to .env"
else
  log_ok "SABNZBD_API_KEY" "read from .env"
fi

usenet_host=$(read_env_value "$ENV_FILE" USENET_SERVER_HOST)
usenet_port=$(read_env_value "$ENV_FILE" USENET_SERVER_PORT); [[ -z "$usenet_port" ]] && usenet_port=563
usenet_user=$(read_env_value "$ENV_FILE" USENET_SERVER_USERNAME)
usenet_conns=$(read_env_value "$ENV_FILE" USENET_SERVER_CONNECTIONS); [[ -z "$usenet_conns" ]] && usenet_conns=20
usenet_pass=$(read_env_value "$ENV_FILE" USENET_SERVER_PASSWORD)

# SABnzbd post-processing script: jobs assemble in complete_dir =
# /downloads/completed/.staging (a reserved directory name Media Centaur's
# watcher never looks inside), and this script moves each *finished* job —
# final names, final content, cruft removed — into /downloads/completed in
# one atomic rename. The scripts dir is stack-managed: refreshed from
# defaults/ on every setup run, so upgrades pick up script fixes.
mkdir -p config/sabnzbd/scripts
cp defaults/sabnzbd/scripts/move-finished.sh config/sabnzbd/scripts/move-finished.sh
chmod +x config/sabnzbd/scripts/move-finished.sh
log_ok "config/sabnzbd/scripts/move-finished.sh" "refreshed from defaults"

# Pre-create the staging dir so the first grab doesn't depend on SABnzbd's
# dir creation happening before the importer's first look.
if [[ -n "$completed_dir" ]]; then
  mkdir -p "$completed_dir/.staging" 2>/dev/null || \
    log_warn "$completed_dir/.staging could not be created — SABnzbd will create it on first use"
fi

SAB_INI="config/sabnzbd/sabnzbd.ini"
if [[ -f "$SAB_INI" ]]; then
  # SABnzbd reads sabnzbd.ini only at startup and rewrites it on shutdown, so a
  # running container would clobber the creds we're about to inject (and Phase 9
  # force-recreates it, guaranteeing that shutdown). Stop it first so our write
  # is the last one; Phase 9 ("starting stack") brings it back to read the fresh
  # config. No-op on a fresh install or when the stack is already down.
  docker compose stop sabnzbd >/dev/null 2>&1 || true
  # --complete-dir/--script-dir/--category-script converge pre-staging
  # installs onto the staged layout (fresh installs already carry these in
  # the seeded ini; re-applying is idempotent).
  printf '%s' "$usenet_pass" | ./scripts/set-sab-config "$SAB_INI" \
    --api-key "$sab_api_key" \
    --server-host "$usenet_host" \
    --server-port "$usenet_port" \
    --server-user "$usenet_user" \
    --connections "$usenet_conns" \
    --complete-dir "/downloads/completed/.staging" \
    --script-dir "/config/scripts" \
    --category-script "move-finished.sh"
  # Holds the API key + plaintext news-server password — keep it owner-only.
  chmod 600 "$SAB_INI"
  log_ok "$SAB_INI" "API key + news-server creds + staging layout written (mode 600)"
  if [[ -z "$usenet_host" ]]; then
    log_warn "USENET_SERVER_* is empty — SABnzbd starts but can't download until you fill .env and re-run ./setup"
  fi
else
  log_warn "$SAB_INI not present — skipping SABnzbd config injection"
fi

if [[ -f config/prowlarr/prowlarr.db ]]; then
  # Ensure the SABnzbd download-client row exists before patching it. On a fresh
  # install the seeded DB already carries it; on an upgrade from a pre-usenet
  # install, setup runs before run-migrations (see ./update), so the live DB has
  # no row yet — materialize it here with the same idempotent migration (no-op
  # when the row is already present) so the patch below never hits an empty set.
  ./migrations/0003-add-sabnzbd-download-client . >/dev/null
  printf '%s' "$sab_api_key" | ./scripts/patch-prowlarr-sab config/prowlarr/prowlarr.db "$lan_ip" 8085 -
  log_ok "prowlarr.db" "SABnzbd download-client host = $lan_ip:8085, API key synced"
else
  log_warn "config/prowlarr/prowlarr.db not present — skipping SABnzbd DB patch"
fi

# --- Phase 7: storage path validation ---
log_phase "storage paths"
storage_mode="interactive"
[[ $NONINTERACTIVE -eq 1 ]] && storage_mode="non-interactive"
validate_storage_paths "$downloads_dir" "$completed_dir" "$allow_non_mountpoint" "$storage_mode"
if [[ "${STORAGE_OPTIN:-0}" == "1" ]]; then
  allow_non_mountpoint=1
  write_env_value "$ENV_FILE" ALLOW_NON_MOUNTPOINT 1
  log_ok "ALLOW_NON_MOUNTPOINT" "1 (persisted to .env)"
fi

# --- Phase 8: systemd user service ---
log_phase "systemd user service"
STACK_DIR="$(pwd)"
SERVICE_DIR="$HOME/.config/systemd/user"
SERVICE_FILE="$SERVICE_DIR/prowlarr-stack.service"
mkdir -p "$SERVICE_DIR"
sed "s|/path/to/media-centaur/prowlarr-stack|$STACK_DIR|g" \
  defaults/prowlarr-stack.service > "$SERVICE_FILE"

# Add RequiresMountsFor under [Unit] when the paths are real kernel mountpoints.
# In ALLOW_NON_MOUNTPOINT=1 mode the paths are plain dirs, so RequiresMountsFor
# would have no effect — keep it out so the unit's intent is legible.
if [[ "$allow_non_mountpoint" != "1" ]]; then
  rmf_paths="$downloads_dir"
  [[ "$completed_dir" != "$downloads_dir" ]] && rmf_paths="$rmf_paths $completed_dir"
  awk -v rmf="RequiresMountsFor=$rmf_paths" '
    /^\[Unit\]/ { print; print rmf; next }
    { print }
  ' "$SERVICE_FILE" > "${SERVICE_FILE}.tmp" && mv "${SERVICE_FILE}.tmp" "$SERVICE_FILE"
fi

systemctl --user daemon-reload
systemctl --user enable prowlarr-stack.service >/dev/null
log_ok "prowlarr-stack.service" "installed and enabled"

# --- Phase 9: start stack ---
log_phase "starting stack"
# --force-recreate replaces any pre-existing same-named containers, so stale
# bind mounts get re-resolved to the current host inode. This matters when a
# user does `rm -rf ~/prowlarr-stack && reinstall` while the stack is up:
# the kernel keeps the old (now-orphaned) inode attached to the running
# container's mount, and a plain `docker compose up -d` is a no-op because
# the container exists. Without --force-recreate, Prowlarr writes its API
# key into a phantom directory that no longer exists on the host.
# --remove-orphans drops containers for services no longer in the compose file
# (e.g. the old `flaresolverr` container after the byparr rename). Safe here:
# docker reads the full active set from COMPOSE_FILE in .env, so the qbt-vpn
# overlay's containers are part of the project, not orphans.
docker compose up -d --force-recreate --remove-orphans
log_ok "containers" "started (recreated for fresh bind mounts)"

# --- Phase 10: wait for tunnel ---
log_phase "waiting for gluetun tunnel (up to 60s)"
if wait_for_gluetun_healthy 60; then
  log_ok "gluetun" "healthy"
else
  log_fail "gluetun" "did not reach healthy state in 60s"
  log_info "last 20 lines of gluetun log:"
  docker logs --tail 20 gluetun 2>&1 | sed 's/^/      /' >&2
  die "aborting — VPN tunnel failed to establish"
fi

# --- Phase 11: verify ---
verify_isolation || die "VPN isolation verification FAILED — see above and check docker logs gluetun"

# --- Phase 12: credentials summary ---
log_phase "credentials & endpoints"

# Prowlarr generates the API key on first startup, then writes it back to
# config.xml. Poll instead of reading once — gluetun-healthy doesn't mean
# Prowlarr has finished initializing.
prowlarr_key=""
if prowlarr_key=$(wait_for_prowlarr_api_key 30); then
  log_ok "Prowlarr API key" "from config/prowlarr/config.xml"
else
  log_warn "Prowlarr API key not yet written after 30s — re-run ./setup, or grab it from the Prowlarr UI later"
fi

echo ""
echo ""
echo "${COLOR_BOLD}${COLOR_GREEN}done.${COLOR_RESET}  record these for your media-centaur download-client config:"
echo ""
echo "  ${COLOR_BOLD}Prowlarr${COLOR_RESET}"
echo "    URL       http://${lan_ip}:9696"
if [[ -n "$prowlarr_key" ]]; then
  echo "    API key   ${COLOR_YELLOW}${prowlarr_key}${COLOR_RESET}"
else
  echo "    API key   ${COLOR_DIM}(open the UI → Settings → General)${COLOR_RESET}"
fi
echo ""
echo "  ${COLOR_BOLD}qBittorrent${COLOR_RESET}"
echo "    URL       http://${lan_ip}:8080"
echo "    Username  admin"
# Display path: prefer ~-relative when install dir is under $HOME, since the
# user's shell is back in their original CWD by now (curl-bootstrap installs
# into ~/prowlarr-stack and ends there). Bare `./check` would not work.
# (The ${var/#pat/replacement} form can't take $HOME as the pattern because
# $HOME contains '/' chars that break the substitution syntax.)
if [[ "$STACK_DIR" == "$HOME"/* ]]; then
  display_dir="~${STACK_DIR#"$HOME"}"
else
  display_dir="$STACK_DIR"
fi
echo "    Password  ${COLOR_YELLOW}${qbt_pw}${COLOR_RESET}   ${COLOR_DIM}(static — change in .env as QBITTORRENT_PASSWORD and re-run ${display_dir}/setup)${COLOR_RESET}"
echo ""
echo "  ${COLOR_BOLD}SABnzbd${COLOR_RESET} ${COLOR_DIM}(usenet)${COLOR_RESET}"
echo "    URL       http://${lan_ip}:8085"
echo "    API key   ${COLOR_YELLOW}${sab_api_key}${COLOR_RESET}"
if [[ -z "$usenet_host" ]]; then
  echo "    ${COLOR_DIM}add your Usenet provider account in .env (USENET_SERVER_*) and re-run ${display_dir}/setup${COLOR_RESET}"
fi
echo ""
echo ""
echo "${COLOR_BOLD}Next step:${COLOR_RESET} add indexers in Prowlarr."
echo "  open ${COLOR_CYAN}http://${lan_ip}:9696${COLOR_RESET} → Indexers → ${COLOR_BOLD}Add Indexer${COLOR_RESET}"
echo "  ${COLOR_DIM}qBittorrent (torrents) and SABnzbd (usenet) are already wired in as download clients.${COLOR_RESET}"
echo ""
echo "verify isolation any time:   ${COLOR_CYAN}${display_dir}/check${COLOR_RESET}"
echo "update stack:                ${COLOR_CYAN}${display_dir}/update${COLOR_RESET}"
echo "stop:                        ${COLOR_CYAN}${display_dir}/scripts/stop${COLOR_RESET}"
