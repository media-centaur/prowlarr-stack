# Copy to .env and fill in. `./setup` will validate and prompt for any missing values.

# Your VPN provider's gluetun slug. Defaults to nordvpn.
# Supported providers: nordvpn, protonvpn, mullvad, surfshark, ivpn, airvpn, windscribe
# — plus any other gluetun-supported WireGuard provider.
VPN_SERVICE_PROVIDER=nordvpn

# WireGuard private key (44-char base64, universal across all providers).
# See README for your provider's extraction steps. Supported providers:
# nordvpn, protonvpn, mullvad, surfshark, ivpn, airvpn, windscribe — plus any
# other gluetun-supported WG provider.
# See the README's "Extracting your WireGuard credentials" section for details.
WIREGUARD_PRIVATE_KEY=

# WireGuard interface address in CIDR notation (e.g. 10.64.222.21/32).
# Required by Mullvad, Surfshark, IVPN, AirVPN, Windscribe.
# Leave blank for NordVPN, ProtonVPN, and other providers that don't need it.
WIREGUARD_ADDRESSES=

# WireGuard preshared key (44-char base64).
# Required by AirVPN, Windscribe.
# Leave blank for all other providers.
WIREGUARD_PRESHARED_KEY=

# Comma-separated exit countries (gluetun picks among them).
# Examples: Netherlands | Switzerland | "United States,Canada"
SERVER_COUNTRIES=Netherlands

# Your LAN subnet in CIDR form. `./setup` auto-detects this.
LAN_SUBNET=

# Your host's LAN IP. `./setup` auto-detects this. Used by Prowlarr to
# reach qBittorrent at http://HOST_LAN_IP:8080.
HOST_LAN_IP=

# Host path bind-mounted into qBittorrent as /downloads. In-flight torrents
# and the incomplete/ subdir live here. `./setup` prompts for this and
# verifies it's an actual mountpoint to prevent silent writes to the root
# filesystem when an OS mount fails to come up.
DOWNLOADS_DIR=/mnt/videos/downloads

# Host path bind-mounted into qBittorrent as /downloads/completed.
# Completed downloads land here. Same mountpoint check applies.
COMPLETED_DIR=/mnt/videos/completed

# Set to 1 to allow DOWNLOADS_DIR / COMPLETED_DIR to be plain directories
# on the root filesystem instead of dedicated mountpoints. Use this only
# on single-disk hosts where you don't have a separate storage volume.
# Default 0 = refuse to start unless the paths are real kernel mounts.
ALLOW_NON_MOUNTPOINT=0

# Route qBittorrent through the gluetun tunnel (1) or direct via your ISP (0).
# Default 0 — direct is recommended:
#   - qBittorrent runs at full ISP speed (VPN tunnels add latency + bandwidth caps)
#   - inbound peer connections work, so seeding actually works
#   - your indexer-browsing in Prowlarr is still hidden by the VPN regardless
# Set to 1 only if you specifically want qBittorrent's IP hidden from peers,
# and accept the speed hit + (for most providers) the loss of inbound peers.
# `./setup` writes COMPOSE_FILE alongside this so docker compose picks up
# the right overlay.
QBITTORRENT_USE_VPN=0

# Which compose files docker compose uses. Set by ./setup based on
# QBITTORRENT_USE_VPN. Don't edit by hand; re-run ./setup --reconfigure.
COMPOSE_FILE=docker-compose.yml
