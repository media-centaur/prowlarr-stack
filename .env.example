# Copy to .env and fill in. `./setup` will validate and prompt for any missing values.

# Your VPN provider's gluetun slug. Defaults to nordvpn.
# Supported providers: nordvpn, protonvpn, mullvad, surfshark, ivpn, airvpn, windscribe
# — plus any other gluetun-supported WireGuard provider.
VPN_SERVICE_PROVIDER=nordvpn

# WireGuard private key (44-char base64, universal across all providers).
# See README for your provider's extraction steps. Supported providers:
# nordvpn, protonvpn, mullvad, surfshark, ivpn, airvpn, windscribe — plus any
# other gluetun-supported WG provider.
# See the README's "Extracting your WireGuard credentials" section for details.
WIREGUARD_PRIVATE_KEY=

# WireGuard interface address in CIDR notation (e.g. 10.64.222.21/32).
# Required by Mullvad, Surfshark, IVPN, AirVPN, Windscribe.
# Leave blank for NordVPN, ProtonVPN, and other providers that don't need it.
WIREGUARD_ADDRESSES=

# WireGuard preshared key (44-char base64).
# Required by AirVPN, Windscribe.
# Leave blank for all other providers.
WIREGUARD_PRESHARED_KEY=

# Comma-separated exit countries (gluetun picks among them).
# Examples: Netherlands | Switzerland | "United States,Canada"
SERVER_COUNTRIES=Netherlands

# Your LAN subnet in CIDR form. `./setup` auto-detects this.
LAN_SUBNET=

# Your host's LAN IP. `./setup` auto-detects this. Used by Prowlarr to
# reach qBittorrent at http://HOST_LAN_IP:8080.
HOST_LAN_IP=
